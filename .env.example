# --- POVINNÉ: přihlášení do hiyori.cz (nastav v Coolify → Environment) ---
HIYORI_USER=Procho
HIYORI_PASS=zde_tvoje_heslo

# --- stahování ---
# DOWNLOAD_ENABLED=false       # zatím VYPNUTO — jen evidujeme co přibylo. Zapneš 'true' později.

# --- volitelné (výchozí hodnoty jsou rozumné) ---
# PORT=8080
# DATA_DIR=/data
# SCRAPE_INTERVAL_MIN=60        # 0 = vypnout automatiku (jen ruční tlačítko)
# RUN_ON_BOOT=true             # spustit scrape hned po startu
# FEED_OVERLAP_MIN=20          # překryv okna feedu proti minulému běhu
# MAX_DETAILS_PER_RUN=80       # strop na počet anime za běh
# REQUEST_DELAY_MS=1500        # pauza mezi requesty (slušnost k serveru)
